# Standard .gitignore file

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor directories and files
.idea/
.vscode/
*.sublime-workspace

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Environment variables
.env
.env.*

# Build directories
dist/
build/

# Temporary files
*.tmp
*.swp
*.swo

# System files
Thumbs.db
Desktop.ini

# private files
private/

# Cloudflare
.wrangler/
.dev.vars
.dev.vars.*
